{
  "name": "project-manager-api",
  "version": "1.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development bun run --watch ./index.ts",
    "typecheck": "bunx tsc --noEmit",
    "start": "NODE_ENV=production bun run --watch ./index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun ./src/db/v1/seed.ts",
    "open:studio": "npx drizzle-kit studio"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.28",
    "http-status-codes": "^2.3.0",
    "nanoid": "^5.1.16",
    "pg": "^8.22.0",
    "slugify": "^1.6.9",
    "zod": "^4.4.3"
  }
}
